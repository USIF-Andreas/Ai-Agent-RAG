APP_NAME=RAG CV Matcher
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api
CORS_ORIGINS=["*"]

DOCUMENTS_DIR=/app/documents
UPLOADS_DIR=/app/uploads
TEMP_DIR=/app/tmp

FAISS_INDEX_PATH=/app/documents/faiss_index
SQLITE_DB_PATH=/app/documents/metadata.db

OLLAMA_BASE_URL=http://ollama:11434
LLM_PROVIDER=ollama
VECTOR_STORE_PROVIDER=faiss
METADATA_STORE_PROVIDER=sqlite
LLM_MODEL=llama3:8b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=3
MAX_CONTEXT_CHUNKS=5

DEFAULT_LANGUAGE=auto
ENABLE_ARABIC_NORMALIZATION=true
ENABLE_FACTORY_PATTERN=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/owl-alpha
