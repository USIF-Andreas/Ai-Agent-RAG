APP_NAME=RAG CV Matcher
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api
CORS_ORIGINS=*

DOCUMENTS_DIR=/app/documents
UPLOADS_DIR=/app/uploads
TEMP_DIR=/app/tmp

MONGODB_URL=mongodb://mongo:27017
MONGODB_DATABASE=rag_app
MONGO_INITDB_ROOT_USERNAME=your_username
MONGO_INITDB_ROOT_PASSWORD=your_password
MONGO_INITDB_DATABASE=rag_app

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=candidate_match_chunks

OLLAMA_BASE_URL=http://ollama:11434
LLM_PROVIDER=summary
VECTOR_STORE_PROVIDER=memory
METADATA_STORE_PROVIDER=noop
LLM_MODEL=phi3:mini
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=256

CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=3
MAX_CONTEXT_CHUNKS=5

DEFAULT_LANGUAGE=auto
SUPPORTED_EXTENSIONS=.txt,.md,.html,.htm,.pdf
ENABLE_ARABIC_NORMALIZATION=true
ENABLE_FACTORY_PATTERN=true